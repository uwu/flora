{
  "name": "@uwu/flora-cli",
  "version": "0.0.1",
  "private": false,
  "description": "flora command line interface",
  "repository": {
    "type": "git",
    "url": "https://github.com/uwu/flora",
    "directory": "packages/cli"
  },
  "bin": {
    "flora": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "publishConfig": {
