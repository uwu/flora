# Copy this file to `.buckconfig.local` if you need machine-local notes.
# Buck actions in this repo expect toolchain env vars to come from your shell.
#
# Example before source-mode builds:
# export V8_FROM_SOURCE=1
# export LIBCLANG_PATH=/usr/lib/llvm-19/lib
# export GN=/usr/bin/gn
# export NINJA=/usr/bin/ninja
# export PYTHON=python3
# export EXTRA_GN_ARGS='is_debug=false'
